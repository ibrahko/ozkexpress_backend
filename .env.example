# Django
DJANGO_SECRET_KEY=change-me-generate-a-strong-key
DJANGO_DEBUG=True
DJANGO_READ_DOT_ENV_FILE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Database
POSTGRES_DB=motoexpress
POSTGRES_USER=motoexpress
POSTGRES_PASSWORD=motoexpress_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Twilio (SMS OTP — utilisé en secours si WhatsApp échoue)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Twilio WhatsApp (OTP — canal principal, moins cher que le SMS)
# TWILIO_WHATSAPP_NUMBER : format "whatsapp:+14155238886" (sandbox) ou ton numéro WhatsApp Business
# TWILIO_WHATSAPP_CONTENT_SID : SID du template catégorie "Authentication" approuvé par Meta
TWILIO_WHATSAPP_NUMBER=
TWILIO_WHATSAPP_CONTENT_SID=
# "whatsapp" (recommandé) ou "sms"
OTP_CHANNEL=whatsapp

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Orange Money
ORANGE_MONEY_API_URL=https://api.orange.com
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=

# Wave
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry
SENTRY_DSN=

# App
APP_BASE_URL=http://localhost:8000
